function Invoke-ChannelSitesProvisioning {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [int]$ProjectCode,

        [Parameter(Mandatory)]
        [string]$ProjectName
    )

    Write-Verbose "Starting channel sites provisioning for project $ProjectCode - $ProjectName"

    # ====================== LOAD CENTRALISED CONFIGURATION ======================
    $appConfig = Import-PowerShellDataFile -Path "$PSScriptRoot\..\Config\AppConfig.psd1"
    $contentConfig = Import-PowerShellDataFile -Path "$PSScriptRoot\..\Config\ContentTypeMapping.psd1"
    $cert = ConvertTo-SecureString -String $appConfig.CertificatePassword -AsPlainText -Force

    # Normalise project name for URLs
    $projectNameUrl = $ProjectName -replace '\s*\|\s*', '' -replace '\s+', ''

    # Channel URL arrays
    $chanGJCTArray = @(
        "$ProjectNameUrl-CommercialDocuments"
    )
    $chanGJDSArray = @(
        "$projectNameUrl-Transmittals-Project",
        "$projectNameUrl-Transmittals-Commercial"
    )
    $chanRFI = "$projectNameUrl-RequestforInformation"
    $chanSurvey = "$projectNameUrl-SurveyData"

    # ====================== PROCESS GREYJONES DOCUMENT CONTENT TYPE CHANNELS ======================
    foreach ($channelGJCTUrl in $chanGJCTArray) {
        $targetUrl = "$($contentConfig.ChannelBaseUrl)$channelGJCTUrl"
        Write-Host "Processing GJCT channel: $targetUrl" -ForegroundColor Cyan
        Wait-ForChannelSite -Url $targetUrl
        Start-Process $targetUrl

        Connect-PnPOnline `
            -Url $targetUrl `
            -ClientId $appConfig.ClientID `
            -Tenant $appConfig.Tenant `
            -CertificatePath $appConfig.CertificatePath `
            -CertificatePassword $cert
        Add-PnPHubSiteAssociation `
            -Site $targetUrl `
            -HubSite $appConfig.HubSiteUrl
        Enable-PnPFeature `
            -Identity $appConfig.SPTaxonomyFeatureId `
            -Scope Site
        Enable-PnPFeature `
            -Identity $appConfig.DocSetFeatureId `
            -Scope Site
        Add-PnPContentTypesFromContentTypeHub -ContentTypes $contentConfig.GreyJonesDocumentCT
        Set-PnPList `
            -Identity $contentConfig.ViewLibraryName `
            -EnableContentTypes $true `
            -EnableFolderCreation $false `
            -OpenDocumentsMode ClientApplication
        Add-PnPContentTypeToList `
            -List $contentConfig.ViewLibraryNameCommercialDocs `
            -ContentType $contentConfig.GreyJonesDocumentCT
        Set-PnPDefaultContentTypeToList `
            -List $contentConfig.ViewLibraryNameCommercialDocs `
            -ContentType $contentConfig.GreyJonesDocumentCT
        Set-PnPSite -LogoFilePath $appConfig.LogoPath

        # Views
        $fields1 = (
            Get-PnPView `
                -List $contentConfig.ViewLibraryNameCommercialDocs `
                -Identity $contentConfig.ViewCommercial1 `
                -Connection (Get-PnPConnection)
        ).ViewFields | ForEach-Object { $_.ToString() }
        $fields2 = (
            Get-PnPView `
                -List $contentConfig.ViewLibraryNameCommercialDocs `
                -Identity $contentConfig.ViewCommercial2 `
                -Connection (Get-PnPConnection)
        ).ViewFields | ForEach-Object { $_.ToString() }
        Add-PnPView `
            -List $contentConfig.ViewLibraryNameCommercialDocs `
            -Title $contentConfig.ViewCommercial1 `
            -Fields $fields1
        Add-PnPView `
            -List $contentConfig.ViewLibraryNameCommercialDocs`
            -Title $contentConfig.ViewCommercial2 `
            -Fields $fields2
        Set-PnPView `
            -List $contentConfig.ViewLibraryNameCommercialDocs `
            -Identity $contentConfig.ViewCommercial1 `
            -Values @{ DefaultView = $true }

        Disconnect-PnPOnline
    }

    # ====================== PROCESS TRANSMITTAL DOCUMENT SET CHANNELS ======================
    foreach ($channelGJDSUrl in $chanGJDSArray) {
        $targetUrl = "$($contentConfig.ChannelBaseUrl)$channelGJDSUrl"
        Write-Host "Processing GJDS channel: $targetUrl" -ForegroundColor Cyan
        Wait-ForChannelSite -Url $targetUrl
        Start-Process $targetUrl

        Connect-PnPOnline `
            -Url $targetUrl `
            -ClientId $appConfig.ClientID `
            -Tenant $appConfig.Tenant `
            -CertificatePath $appConfig.CertificatePath `
            -CertificatePassword $cert
        Add-PnPHubSiteAssociation `
            -Site $targetUrl `
            -HubSite $appConfig.HubSiteUrl
        Enable-PnPFeature `
            -Identity $appConfig.SPTaxonomyFeatureId `
            -Scope Site
        Enable-PnPFeature `
            -Identity $appConfig.DocSetFeatureId `
            -Scope Site
        Add-PnPContentTypesFromContentTypeHub -ContentTypes $contentConfig.TransmittalDocumentCT
        Add-PnPContentTypesFromContentTypeHub -ContentTypes $contentConfig.TransmittalDocumentSet
        Set-PnPList `
            -Identity $contentConfig.ViewLibraryName `
            -EnableContentTypes $true `
            -EnableFolderCreation $false `
            -OpenDocumentsMode ClientApplication
        Add-PnPContentTypeToList `
            -List $contentConfig.ViewLibraryName `
            -ContentType $contentConfig.TransmittalDocumentCT
        Add-PnPContentTypeToList `
            -List $contentConfig.ViewLibraryName `
            -ContentType $contentConfig.TransmittalDocumentSet
        Set-PnPDefaultContentTypeToList `
            -List $contentConfig.ViewLibraryName `
            -ContentType $contentConfig.TransmittalDocumentCT
        Set-PnPSite -LogoFilePath $appConfig.LogoPath

        # Transmittal views
        $fields1 = (
            Get-PnPView `
                -List $contentConfig.ViewLibraryName `
                -Identity $contentConfig.ViewTransmittals1 `
                -Connection (Get-PnPConnection)
        ).ViewFields | ForEach-Object { $_.ToString() }
        $fields2 = (
            Get-PnPView `
                -List $contentConfig.ViewLibraryName `
                -Identity $contentConfig.ViewTransmittals2 `
                -Connection (Get-PnPConnection)
        ).ViewFields | ForEach-Object { $_.ToString() }
        Add-PnPView `
            -List $contentConfig.ViewLibraryName `
            -Title $contentConfig.ViewTransmittals1 `
            -Fields $fields1
        Add-PnPView `
            -List $contentConfig.ViewLibraryName `
            -Title $contentConfig.ViewTransmittals2 `
            -Fields $fields2
        Set-PnPView `
            -List $contentConfig.ViewLibraryName `
            -Identity $contentConfig.ViewTransmittals1 `
            -Values @{ DefaultView = $true }

        Disconnect-PnPOnline
    }

    # ====================== PROCESSS RFI CHANNEL ======================
    $targetRFIUrl = "$($contentConfig.ChannelBaseUrl)$chanRFI"
    Write-Host "Processing RFI channel: $targetRFIUrl" -ForegroundColor Cyan
    Start-Process $targetRFIUrl
    Connect-PnPOnline `
        -Url $targetRFIUrl `
        -ClientId $appConfig.ClientID `
        -Tenant $appConfig.Tenant `
        -CertificatePath $appConfig.CertificatePath `
        -CertificatePassword $cert
    Enable-PnPFeature `
        -Identity $appConfig.SPTaxonomyFeatureId `
        -Scope Site
    Enable-PnPFeature `
        -Identity $appConfig.DocSetFeatureId `
        -Scope Site
    Add-PnPHubSiteAssociation `
        -Site $targetRFIUrl `
        -HubSite $appConfig.HubSiteUrl
    Add-PnPContentTypesFromContentTypeHub -ContentTypes $contentConfig.RFIContentType
    Set-PnPSite -LogoFilePath $appConfig.LogoPath
    Invoke-PnPSiteTemplate -Path $appConfig.RFITemplatePath

    Disconnect-PnPOnline

    Write-Verbose "Channel sites provisioning for $ProjectCode completed."

    # ====================== PROCESS SURVEY CHANNEL ======================
    $targetSurveyUrl = "$($contentConfig.ChannelBaseUrl)$chanSurvey"
    Write-Host "Processing Survey Data channel: $targetSurveyUrl" -ForegroundColor Cyan
    Start-Process $targetSurveyUrl
    Connect-PnPOnline `
        -Url $targetSurveyUrl `
        -ClientId $appConfig.ClientID `
        -Tenant $appConfig.Tenant `
        -CertificatePath $appConfig.CertificatePath `
        -CertificatePassword $cert
    Enable-PnPFeature `
        -Identity $appConfig.SPTaxonomyFeatureId `
        -Scope Site
    Enable-PnPFeature `
        -Identity $appConfig.DocSetFeatureId `
        -Scope Site
    Add-PnPHubSiteAssociation `
        -Site $targetSurveyUrl `
        -HubSite $appConfig.HubSiteUrl
    Add-PnPContentTypesFromContentTypeHub -ContentTypes $contentConfig.GreyJonesImageCT

    Set-PnPList `
        -Identity $contentConfig.ViewLibraryNameSurvey `
        -EnableContentTypes $true `
        -EnableFolderCreation $false `
        -OpenDocumentsMode ClientApplication
    Add-PnPContentTypeToList `
        -List $contentConfig.ViewLibraryNameSurvey `
        -ContentType $contentConfig.GreyJonesImageCT
    Set-PnPDefaultContentTypeToList `
        -List $contentConfig.ViewLibraryNameSurvey `
        -ContentType $contentConfig.GreyJonesImageCT

    Set-PnPSite -LogoFilePath $appConfig.LogoPath

    # Survey Data view
    $fieldSurvey1 = (
        Get-PnPView `
            -List $contentConfig.ViewLibraryName `
            -Identity $contentConfig.ViewTransmittals1 `
            -Connection (Get-PnPConnection)
    ).ViewFields | ForEach-Object { $_.ToString() }


    Disconnect-PnPOnline

    Write-Verbose "Channel sites provisioning for $ProjectCode completed."
}